        "type": "object",
        "properties": { "isTfaEnabled": { "type": "boolean", "example": true } },
        "required": ["isTfaEnabled"]
      },
      "ConfirmEmailBodyDTO": {
        "type": "object",
        "properties": { "token": { "type": "string", "example": "string", "pattern": "/^[\\w\\d]{32}$/" } },
        "required": ["token"]
      },
      "VerifyEmailConfirmationTokenBodyDTO": {
        "type": "object",
        "properties": { "token": { "type": "string", "example": "string", "pattern": "/^[\\w\\d]{32}$/" } },
