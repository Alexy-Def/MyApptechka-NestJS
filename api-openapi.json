      },
      "GenerateSecretResponseDTO": {
        "type": "object",
        "properties": {
          "otpAuthUrl": { "type": "string", "example": "string" },
          "secret": { "type": "string", "example": "string" }
        },
        "required": ["otpAuthUrl", "secret"]
      },
      "ChangeSecretBodyDTO": {
        "type": "object",
        "properties": { "code": { "type": "string", "example": "string", "maxLength": 6, "minLength": 6 } },
        "required": ["code"]
      },
      "ChangeSecretResponseDTO": {
        "type": "object",
        "properties": {
          "otpAuthUrl": { "type": "string", "example": "string" },
          "secret": { "type": "string", "example": "string" }
        },
        "required": ["otpAuthUrl", "secret"]
      },
      "VerifyCodeBodyDTO": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "string", "maxLength": 6, "minLength": 6 },
          "useNewSecret": { "type": "boolean", "example": true }
        },
        "required": ["code"]
      }
