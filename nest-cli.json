{
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "utils": {
      "type": "library",
      "root": "libs/utils",
      "entryFile": "index",
      "sourceRoot": "libs/utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/utils/tsconfig.lib.json"
      }
    },
    "api-decorators": {
      "type": "library",
      "root": "libs/api-decorators",
      "entryFile": "index",
      "sourceRoot": "libs/api-decorators/src",
      "compilerOptions": {
        "tsConfigPath": "libs/api-decorators/tsconfig.lib.json"
      }
    },
    "typeorm-ext": {
      "type": "library",
      "root": "libs/typeorm-ext",
      "entryFile": "index",
      "sourceRoot": "libs/typeorm-ext/src",
      "compilerOptions": {
        "tsConfigPath": "libs/typeorm-ext/tsconfig.lib.json"
      }
    },
    "api-client-types": {
      "type": "library",
      "root": "libs/api-client-types",
      "entryFile": "index",
      "sourceRoot": "libs/api-client-types/src",
      "compilerOptions": {
        "tsConfigPath": "libs/api-client-types/tsconfig.lib.json"
      }
    },
    "s3": {
      "type": "library",
      "root": "libs/s3",
      "entryFile": "index",
      "sourceRoot": "libs/s3/src",
      "compilerOptions": {
        "tsConfigPath": "libs/s3/tsconfig.lib.json"
      }
    },
    "nestjs-logger": {
      "type": "library",
      "root": "libs/nestjs-logger",
      "entryFile": "index",
      "sourceRoot": "libs/nestjs-logger/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nestjs-logger/tsconfig.lib.json"
      }
    }
  },
  "compilerOptions": {
    "builder": "webpack",
    "tsConfigPath": "apps/api/tsconfig.app.json",
    "assets": ["**/*.handlebars"]
  },
  "monorepo": true,
  "root": "apps/api"
}
